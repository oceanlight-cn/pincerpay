  "peerDependenciesMeta": {
    "@x402/express": { "optional": true },
    "@x402/hono": { "optional": true },
    "express": { "optional": true },
    "hono": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5",
    "@x402/express": "^2.3",
    "@x402/hono": "^2.3",
    "express": "^5",
    "hono": "^4",
    "typescript": "^5.7"
  }
