{
  "name": "@pincerpay/merchant",
  "version": "0.4.1",
  "type": "module",
  "description": "Merchant SDK for PincerPay. Express and Hono middleware for accepting USDC payments from AI agents.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/merchant"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "keywords": [
    "pincerpay",
    "x402",
    "usdc",
    "payments",
    "ai-agents",
    "solana",
    "merchant-sdk",
    "middleware",
    "express",
    "hono",
    "typescript",
    "web3",
    "crypto",
    "on-chain",
    "http-402",
    "paywall",
    "api-monetization",
    "machine-to-machine"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js"
    },
    "./hono": {
      "types": "./dist/middleware/hono.d.ts",
      "import": "./dist/middleware/hono.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pincerpay/core": "workspace:*",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "zod": "^3.24"
  },
  "peerDependencies": {
    "@x402/express": "^2.3",
    "@x402/hono": "^2.3",
    "express": "^4 || ^5",
    "hono": "^4"
  },
  "peerDependenciesMeta": {
    "@x402/express": {
      "optional": true
    },
    "@x402/hono": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5",
    "@x402/express": "^2.6.0",
    "@x402/hono": "^2.6.0",
    "express": "^5",
    "hono": "^4.12.0",
    "typescript": "^5.7"
  }
}
