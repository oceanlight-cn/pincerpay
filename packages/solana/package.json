{
  "name": "@pincerpay/solana",
  "version": "0.4.1",
  "type": "module",
  "description": "Solana integration for PincerPay. Kora gasless transactions and Squads smart account support.",
  "license": "MIT",
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/solana"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pincerpay",
    "solana",
    "kora",
    "squads",
    "gasless",
    "usdc",
    "smart-accounts",
    "session-keys",
    "typescript",
    "web3",
    "crypto",
    "on-chain",
    "http-402",
    "spl-token",
    "transfer-checked",
    "devnet",
    "mainnet"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kora": {
      "types": "./dist/kora/index.d.ts",
      "import": "./dist/kora/index.js"
    },
    "./squads": {
      "types": "./dist/squads/index.d.ts",
      "import": "./dist/squads/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pincerpay/core": "workspace:*",
    "@solana/kit": "^5.5.1",
    "@x402/svm": "^2.6.0",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@scure/base": "^1.2.6",
    "typescript": "^5.7"
  }
}
