{
  "name": "@pincerpay/agent",
  "version": "0.4.1",
  "type": "module",
  "description": "Agent SDK for PincerPay. Drop-in fetch wrapper that handles x402 payment flows automatically.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "keywords": [
    "pincerpay",
    "x402",
    "usdc",
    "payments",
    "ai-agents",
    "solana",
    "agent-sdk",
    "payment-gateway",
    "stablecoin",
    "typescript",
    "web3",
    "crypto",
    "on-chain",
    "http-402",
    "fetch-wrapper",
    "autonomous",
    "spending-policy",
    "agentic"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pincerpay/core": "workspace:*",
    "@pincerpay/solana": "workspace:*",
    "@solana/kit": "^5.5.1",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "viem": "^2",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@scure/base": "^1.2.6",
    "typescript": "^5.7"
  }
}
