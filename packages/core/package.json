{
  "name": "@pincerpay/core",
  "version": "0.5.0",
  "type": "module",
  "description": "Shared types, chain configs, and constants for PincerPay on-chain payment gateway",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "keywords": [
    "pincerpay",
    "x402",
    "usdc",
    "payments",
    "ai-agents",
    "solana",
    "payment-gateway",
    "stablecoin",
    "typescript",
    "web3",
    "crypto",
    "on-chain",
    "http-402",
    "types",
    "chain-config",
    "constants"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "import": "./dist/chains/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24"
  },
  "devDependencies": {
    "typescript": "^5.7"
  }
}
