{
  "name": "@pincerpay/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for PincerPay — on-chain USDC payment gateway for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pincerpay-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26",
    "@pincerpay/core": "workspace:*",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pincerpay",
    "x402",
    "usdc",
    "payments",
    "ai-agents",
    "solana",
    "payment-gateway",
    "stablecoin"
  ],
  "license": "MIT"
}
