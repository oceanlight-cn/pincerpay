{
  "name": "@pincerpay/program",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Anchor program client for PincerPay Solana on-chain settlement.",
  "license": "MIT",
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/program"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "keywords": [
    "pincerpay",
    "solana",
    "anchor",
    "program",
    "usdc",
    "settlement",
    "on-chain"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pincerpay/core": "workspace:*",
    "@solana/kit": "^5.5.1"
  },
  "devDependencies": {
    "typescript": "^5.7"
  }
