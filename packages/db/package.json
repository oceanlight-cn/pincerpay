{
  "name": "@pincerpay/db",
  "version": "0.1.0",
  "type": "module",
  "description": "Database schema and migrations for PincerPay. Drizzle ORM with PostgreSQL.",
  "license": "MIT",
  "homepage": "https://pincerpay.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ds1/pincerpay.git",
    "directory": "packages/db"
  },
  "bugs": {
    "url": "https://github.com/ds1/pincerpay/issues"
  },
  "keywords": ["pincerpay", "database", "drizzle", "postgresql", "schema"],
  "files": ["dist", "README.md"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "tsc && drizzle-kit push",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.38",
    "postgres": "^3.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "drizzle-kit": "^0.30",
    "typescript": "^5.7"
  }
}
