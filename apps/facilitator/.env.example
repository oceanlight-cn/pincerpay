# Facilitator Configuration
PORT=4402
NODE_ENV=development
LOG_LEVEL=info

# Database (Supabase PostgreSQL direct connection)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Facilitator wallet (EVM) — used to broadcast transactions
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
FACILITATOR_PRIVATE_KEY=0x...

# Supported EVM networks (comma-separated CAIP-2 IDs)
# Testnet: eip155:84532 (Base Sepolia), eip155:80002 (Polygon Amoy)
# Mainnet: eip155:8453 (Base), eip155:137 (Polygon)
EVM_NETWORKS=eip155:84532

# Facilitator wallet (Solana) — base58-encoded 64-byte keypair (optional)
# SOLANA_PRIVATE_KEY=...

# Supported Solana networks (comma-separated CAIP-2 IDs, optional)
# Devnet: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# SOLANA_NETWORKS=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Custom RPC URLs (JSON format, optional — works for both EVM and Solana)
# RPC_URLS={"eip155:84532":"https://sepolia.base.org","solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1":"https://api.devnet.solana.com"}

# CORS allowed origins (comma-separated, leave empty for "*" in development)
# CORS_ORIGINS=https://dashboard.pincerpay.com,https://api.yourdomain.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=120
