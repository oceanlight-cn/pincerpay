{
  "name": "pincerpay",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @pincerpay/db generate",
    "db:migrate": "pnpm --filter @pincerpay/db migrate",
    "db:push": "pnpm --filter @pincerpay/db push",
    "db:seed": "pnpm --filter @pincerpay/db build && node packages/db/dist/seed.js"
  },
  "pnpm": {
    "overrides": {
      "bn.js@>=5 <5.2.3": "5.2.3",
      "minimatch@<10.2.3": "10.2.3",
      "hono@<4.12.2": "4.12.3",
      "rollup@>=4 <4.59.0": "4.59.0"
    }
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
