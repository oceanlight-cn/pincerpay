    "discord-bot": "tsx src/agents/discord-bot.ts",
    "review": "tsx src/cli/index.ts review",
    "calendar": "tsx src/cli/index.ts calendar",
    "report": "tsx src/cli/index.ts report",
    "status": "tsx src/cli/index.ts status",
