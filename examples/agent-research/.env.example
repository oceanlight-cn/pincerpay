# PincerPay Agent Research Example
# Copy this to .env and fill in your values

# Required: Solana private key (base58 encoded)
# Generate with: solana-keygen new -o key.json
AGENT_SOLANA_KEY=your_solana_private_key_here

# Optional: EVM private key (hex encoded, for Base/Polygon)
AGENT_EVM_KEY=

# Required: Get from https://pincerpay.com/dashboard
PINCERPAY_API_KEY=your_api_key_here

# Required: Your Solana wallet address (will receive payments)
MERCHANT_ADDRESS=your_solana_address_here

# Optional: Merchant API URL (default: http://localhost:3001)
MERCHANT_URL=http://localhost:3001
